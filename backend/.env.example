# Base de datos PostgreSQL
DATABASE_URL="postgresql://postgres:TU_PASSWORD@localhost:5433/bes_db?schema=public"

# Clave de encriptación AES-256 — DEBE ser exactamente 32 caracteres
# Generar con: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# URL del frontend (para CORS)
FRONTEND_URL="http://localhost:3001"

# URL pública del backend (para construir URLs de PDFs en la BD)
BACKEND_URL="http://localhost:3000"

# Secreto JWT — puede ser cualquier string largo y aleatorio
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Redis (para BullMQ)
REDIS_HOST="localhost"
REDIS_PORT="6379"
# REDIS_PASSWORD=""
# REDIS_TLS="false"

# Puerto del servidor NestJS
PORT="3000"

# Configuración de correo (Nodemailer)
# MAIL_HOST=""
# MAIL_PORT=""
# MAIL_USER=""
# MAIL_PASS=""

# Puppeteer (true para modo oculto en Docker/producción, false para ver el navegador gráficamente en desarrollo)
PUPPETEER_HEADLESS="true"
